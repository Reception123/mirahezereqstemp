{
	"name": "MirahezeRequests",
	"author": "Pskyechology",
	"url": "https://github.com/miraheze/MirahezeRequests",
	"descriptionmsg": "mirahezerequests-desc",
	"namemsg": "mirahezerequests-extensionname",
	"license-name": "GPL-3.0-or-later",
	"type": "specialpage",
	"requires": {
		"MediaWiki": ">= 1.45.0",
		"platform": {
			"php": ">= 8.4"
		}
	},
	"MessagesDirs": {
		"MirahezeRequests": [
			"i18n"
		]
	},
	"ExtensionMessagesFiles": {
		"MirahezeRequestsAliases": "MirahezeRequestsAliases.php"
	},
	"AutoloadNamespaces": {
		"Miraheze\\MirahezeRequests\\": "includes/"
	},
	"TestAutoloadNamespaces": {
		"Miraheze\\MirahezeRequests\\Tests\\": "tests/phpunit/"
	},
	"JobClasses": {
		"MirahezeRequestsCreateAccountJob": {
			"class": "Miraheze\\MirahezeRequests\\Jobs\\CreateAccountJob",
			"services": [
				"UserFactory",
				"AuthManager"
			],
			"needsPage": false
		},
		"RenameWikiJob": {
			"class": "Miraheze\\MirahezeRequests\\Jobs\\RenameWikiJob",
			"services": [
				"ConnectionProvider",
				"MirahezeRequestsConfig",
				"RenameWikiHookRunner",
				"RenameWikiRequestManager",
				"JobQueueGroupFactory",
				"WikiImporterFactory"
			],
			"needsPage": false
		},
		"RenameWikiNotifyJob": {
			"class": "Miraheze\\MirahezeRequests\\Jobs\\RenameWikiNotifyJob",
			"services": [
				"ExtensionRegistry",
				"MirahezeRequestsConfig",
				"RenameWikiRequestManager",
				"UserFactory"
			],
			"needsPage": false
		}
	},
	"GroupPermissions": {
		"user": {
			"request-renamewiki": true
		}
	},
	"AvailableRights": [
		"handle-renamewiki-request-interwiki",
		"handle-renamewiki-requests",
		"request-renamewiki",
		"view-private-renamewiki-requests",
		"handle-requestaccount",
		"request-account"
	],
	"LogActionsHandlers": {
		"renamewiki/*": "MediaWiki\\Logging\\LogFormatter",
		"renamewikiprivate/*": "MediaWiki\\Logging\\LogFormatter",
		"requestaccount/*": "MediaWiki\\Logging\\LogFormatter"
	},
	"LogHeaders": {
		"renamewiki": "renamewiki-log-header",
		"renamewikiprivate": "renamewikiprivate-log-header",
		"requestaccount": "requestaccount-log-header"
	},
	"LogNames": {
		"renamewiki": "renamewiki-log-name",
		"renamewikiprivate": "renamewikiprivate-log-name",
		"requestaccount": "requestaccount-log-name"
	},
	"LogTypes": [
		"renamewiki",
		"renamewikiprivate",
		"requestaccount"
	],
	"LogRestrictions": {
		"renamewikiprivate": "view-private-renamewiki-requests"
	},
	"ActionFilteredLogs": {
		"renamewiki": {
			"interwiki": [
				"interwiki"
			],
			"request": [
				"request"
			],
			"started": [
				"started"
			],
			"statusupdate": [
				"statusupdate"
			]
		},
		"renamewikiprivate": {
			"interwiki": [
				"interwiki"
			],
			"request": [
				"request"
			],
			"started": [
				"started"
			],
			"statusupdate": [
				"statusupdate"
			]
		}
	},
	"SpecialPages": {
		"RequestAccount": {
			"class": "Miraheze\\MirahezeRequests\\Specials\\SpecialRequestAccount",
			"services": [
				"MirahezeRequestsDatabaseService"
			]
		},
		"RequestAccountQueue": {
			"class": "Miraheze\\MirahezeRequests\\Specials\\Queue\\SpecialRequestAccountQueue",
			"services": [
				"MirahezeRequestsDatabaseService",
				"RequestAccountManager",
				"UserFactory"
			]
		},
		"RequestDPE": {
			"class": "Miraheze\\MirahezeRequests\\Specials\\SpecialRequestDPE",
			"services": [
				"MirahezeRequestsDatabaseService"
			]
		},
		"RequestRenameWiki": {
			"class": "Miraheze\\MirahezeRequests\\Specials\\SpecialRequestRenameWiki",
			"services": [
				"ConnectionProvider",
				"MirahezeRequestsValidator",
				"ExtensionRegistry",
				"UserFactory"
			],
			"optional_services": [
				"ManageWikiModuleFactory"
			]
		}
	},
	"ResourceModules": {
		"ext.mirahezerequests.tabs": {
			"class": "MediaWiki\\ResourceLoader\\CodexModule",
			"codexComponents": [
				"CdxMessage",
				"CdxTabs",
				"CdxTab"
			],
			"dependencies": [
				"vue"
			],
			"packageFiles": [
				"ext.mirahezerequests.tabs/init.js",
				"ext.mirahezerequests.tabs/App.vue"
			]
		}
	},
	"ResourceFileModulePaths": {
		"localBasePath": "resources",
		"remoteExtPath": "MirahezeRequests/resources"
	},
	"config": {
		"MirahezeRequestsDatabaseSuffix": {
			"value": "wiki",
			"description": "String. Database suffix."
		},
		"RenameWikiEnableAutomatedJob": {
			"value": true,
			"description": "Whether to enable a job where a reviewer just has to 'approve' an renamewiki and job handles everything else. You can use the RenameWikiJobGetFile hook to manipulate how the job gets the XML file."
		},
		"RenameWikiHelpUrl": {
			"value": "",
			"description": "Full URL. If set, adds a help URL to Special:RequestRenameWiki."
		},
		"RenameWikiInterwikiMap": {
			"value": [],
			"description": "A mapping of 'domain => interwiki prefix' for multi-level interwiki prefix generation for --username-prefix."
		},
		"RenameWikiScriptCommand": {
			"value": "mwscript MirahezeMagic:RenameDatabase loginwiki --rename --old={oldwiki} --new={newwiki} --user=Restricted_Workflows",
			"description": "Generated maintenance script command to use. If $wgRenameWikiEnableAutomatedJob is enabled, this is not displayed unless the status is 'failed'."
		},
		"RenameWikiUsersNotifiedOnAllRequests": {
			"value": [],
			"description": "Array of usernames to send email notifications to for all requests. Users listed here must have a verified email address on their account. This doesn't do anything if the Echo extension is not installed."
		},
		"RenameWikiUsersNotifiedOnFailedRenameWikis": {
			"value": [],
			"description": "Array of usernames to send email notifications to for failed renamewikis. Users listed here must have a verified email address on their account. This doesn't do anything if the Echo extension is not installed or if $wgRenameWikiEnableAutomatedJob is not enabled."
		}
	},
	"ConfigRegistry": {
		"MirahezeRequests": "MediaWiki\\Config\\GlobalVarConfig::newInstance"
	},
	"DefaultUserOptions": {
		"echo-subscriptions-email-renamewiki-renamewiki-failed": true,
		"echo-subscriptions-email-renamewiki-new-request": true,
		"echo-subscriptions-email-renamewiki-request-comment": true,
		"echo-subscriptions-email-renamewiki-request-status-update": true,
		"echo-subscriptions-web-renamewiki-request-comment": true,
		"echo-subscriptions-web-renamewiki-request-status-update": true
	},
	"RateLimits": {
		"request-renamewiki": {
			"user": [
				5,
				60
			]
		}
	},
	"ServiceWiringFiles": [
		"includes/ServiceWiring.php"
	],
	"Hooks": {
		"LoadExtensionSchemaUpdates": {
			"handler": "Installer"
		},
		"UserGetReservedNames": {
			"handler": "Main"
		}
	},
	"HookHandlers": {
		"Installer": {
			"class": "Miraheze\\MirahezeRequests\\Hooks\\Handlers\\Installer"
		},
		"Main": {
			"class": "Miraheze\\MirahezeRequests\\Hooks\\Handlers\\Main"
		}
	},
	"DatabaseVirtualDomains": [
		"virtual-mirahezerequests"
	],
	"manifest_version": 2
}
